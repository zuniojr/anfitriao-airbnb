---
interface Props {
	title: string;
    description?: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- SEO e Metadados -->
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    
    <link rel="stylesheet" href="/styles.css">
    <!-- Ícones e Fonts -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/favicon.png">
    <!-- <script defer src="/_vercel/insights/script.js"></script> -->
</head>
<body>
    <!-- Header / Navbar -->
    <header class="navbar">
        <div class="logo-container">
            <a href="/" style="text-decoration: none;">
                <h1><i class="fa-solid fa-house-user"></i> <span style="color: black;">Anfitrião</span> Airbnb</h1>
            </a>
        </div>
        <nav>
            <ul class="nav-links">
                <li><a href="/">Início</a></li>
                <li><a href="/dicas">Dicas para Anfitriões</a></li>
                <li><a href="/precificacao">Precificação Inteligente</a></li>
                <li><a href="/gestao">Gestão e Automação</a></li>
                <li><a href="/sobre">Sobre</a></li>
            </ul>
        </nav>
        <div class="nav-actions">
            <a href="/#newsletter" class="btn-primary">Baixar Guia Grátis</a>
        </div>
    </header>

    <slot />

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-grid">
            <div class="footer-about">
                <a href="/" style="text-decoration: none; color: inherit;">
                    <h3><i class="fa-solid fa-house-user"></i> <span style="color: black;">Anfitrião</span> Airbnb</h3>
                </a>
                <p>O maior portal educacional para anfitriões e gestores de aluguel por temporada no Brasil.</p>
            </div>
            <div class="footer-links">
                <h4>Guias Principais</h4>
                <ul>
                    <li><a href="/dicas">Como começar do zero</a></li>
                    <li><a href="/regras">Regras da Casa Ideais</a></li>
                </ul>
            </div>
            <div class="footer-links">
                <h4>Monetize seu Imóvel</h4>
                <ul>
                    <li><a href="/ferramentas">Ferramentas Essenciais</a></li>
                    <li><a href="/consultoria">Mentoria VIP</a></li>
                </ul>
            </div>
            <div class="footer-links">
                <h4>Institucional</h4>
                <ul>
                    <li><a href="/sobre">Sobre a Empresa</a></li>
                    <li><a href="/contato">Contato & Parcerias</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            &copy; 2026 Anfitriões Airbnb. Todos os direitos reservados.
        </div>
    </footer>
    <script src="/scripts.js" is:inline></script>
</body>
</html>
