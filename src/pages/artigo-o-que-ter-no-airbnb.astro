                    <span class="tag-item tag-star"><i class="fa-solid fa-star"></i> Armário/espaço para bagagens</span>
                    <span class="tag-item"><i class="fa-solid fa-check"></i> Mapa impresso da cidade</span>
                    <span class="tag-item"><i class="fa-solid fa-check"></i> Parcerias com atrações locais</span>
                    <span class="tag-item"><i class="fa-solid fa-check"></i> Espelho de corpo inteiro</span>
                    <span class="tag-item"><i class="fa-solid fa-check"></i> Informações de transporte público</span>
                </div>
            </div>

            <!-- PERFIL 8: Estudantes/Concursandos -->
