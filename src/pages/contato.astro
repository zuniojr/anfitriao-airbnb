---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contato e Parcerias | Anfitriões Airbnb" description="Entre em contato com a equipe do Anfitriões Airbnb para tirar dúvidas, sugerir temas, firmar parcerias e contratar consultorias em gestão de propriedades de curta temporada.">


    <div class="page-header">
        <h1>Fale com Especialistas</h1>
        <p>Preencha o formulário abaixo ou envie um e-mail para nossa equipe.</p>
    </div>

    <main class="contact-container">
        <div class="contact-info">
            <p><i class="fa-solid fa-envelope"></i> contato@anfitrioesairbnb.com</p>
            <p><i class="fa-brands fa-whatsapp"></i> (11) 99999-9999 (Apenas WhatsApp Corporativo)</p>
        </div>

        <form class="contact-form" name="contato" method="POST" data-netlify="true" netlify-honeypot="bot-field">
            <input type="hidden" name="form-name" value="contato" />
            <p style="display: none;"><label>Não preencha isso: <input name="bot-field" /></label></p>
            
            <div class="contact-grid">
                <input type="text" name="nome" placeholder="Seu Nome Completo" required>
                <input type="email" name="email" placeholder="E-mail Profissional" required>
            </div>
            
            <select name="assunto" required>
                <option value="" disabled selected>Sobre qual assunto você quer falar?</option>
                <option value="Dúvida Geral">Dúvida sobre um Artigo</option>
                <option value="Consultoria">Quero Contratar Consultoria para meu Imóvel</option>
                <option value="Parceria B2B">Parcerias e Anúncios B2B (Mídia)</option>
                <option value="Outro">Outro assunto</option>
            </select>
            
            <textarea name="mensagem" rows="6" placeholder="Escreva os detalhes da sua mensagem..." required></textarea>
            
            <button type="submit" class="btn-primary" style="width: 100%; border-radius: 4px;">Enviar Mensagem</button>
        </form>
    </main>            <!-- Footer -->
    
</Layout>
