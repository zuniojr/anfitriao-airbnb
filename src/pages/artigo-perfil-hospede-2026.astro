                    </a>
                    <a href="/artigo-hospedes-dificeis" class="related-card">
                        <span><i class="fa-solid fa-shield-halved"></i> Conflito</span>
                        <p>Lidando com Hóspedes Difíceis</p>
                    </a>
                    <a href="/artigo-titulo-descricao" class="related-card">
